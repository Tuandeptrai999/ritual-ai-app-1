{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "api-worker",
	"main": "src/index.ts",
	"compatibility_date": "2026-03-10",
	"observability": {
		"enabled": true
	},
	"compatibility_flags": [
		"nodejs_compat"
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "chatbot-db",
			"database_id": "chatbot-db"
		}
	]
}